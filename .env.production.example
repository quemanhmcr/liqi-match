# Production must always use API runtime and an explicitly approved project.
# After changing EXPO_PUBLIC_* values, restart Metro and fully reload the app.
EXPO_PUBLIC_APPLICATION_RUNTIME_MODE=api
EXPO_PUBLIC_BACKEND_TARGET=production-runtime
EXPO_PUBLIC_EXPECTED_SUPABASE_PROJECT_REF=replace-with-approved-production-ref
APP_VARIANT=production
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-production-publishable-key
EXPO_PUBLIC_MEDIA_BASE_URL=https://media.example.com

# Server-only values. Set these in Supabase function secrets, Cloudflare secrets,
# and CI secret stores. Never expose them through EXPO_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_JWKS_URL=https://your-production-project.supabase.co/auth/v1/.well-known/jwks.json
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=liqi-match-media-production

MEDIA_WORKER_INTERNAL_URL=https://media.example.com
MEDIA_WORKER_INTERNAL_TOKEN=
# Set the same value as Cloudflare INTERNAL_WORKER_TOKEN.
