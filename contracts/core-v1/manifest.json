{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contractSet": "core-v1",
  "version": "1.0.0",
  "description": "Machine-readable provider contracts for secure identity and authoritative player lifecycle.",
  "schemas": {
    "AccountId": {
      "type": "string",
      "format": "uuid",
      "x-semantic": "auth subject / sub"
    },
    "PlayerId": {
      "type": "string",
      "format": "uuid",
      "x-semantic": "canonical player identity"
    },
    "ProfileId": {
      "type": "string",
      "format": "uuid",
      "x-semantic": "canonical profile identity"
    },
    "SessionId": { "type": "string", "minLength": 1, "maxLength": 160 },
    "RequestId": { "type": "string", "minLength": 8, "maxLength": 160 },
    "IdempotencyKey": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "PlayerLifecycleStateV1": {
      "type": "string",
      "enum": [
        "registered",
        "onboarding",
        "active",
        "suspended",
        "deleting",
        "deleted"
      ]
    },
    "AuthenticatedPrincipalV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accountId",
        "playerId",
        "sessionId",
        "issuedAt",
        "expiresAt"
      ],
      "properties": {
        "accountId": { "$ref": "#/schemas/AccountId" },
        "playerId": {
          "anyOf": [{ "$ref": "#/schemas/PlayerId" }, { "type": "null" }]
        },
        "sessionId": { "$ref": "#/schemas/SessionId" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "PlayerLifecycleSnapshotV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "playerId",
        "profileId",
        "state",
        "version",
        "discoverable",
        "messagingAllowed",
        "updatedAt"
      ],
      "properties": {
        "playerId": { "$ref": "#/schemas/PlayerId" },
        "profileId": { "$ref": "#/schemas/ProfileId" },
        "state": { "$ref": "#/schemas/PlayerLifecycleStateV1" },
        "version": { "type": "integer", "minimum": 0 },
        "discoverable": { "type": "boolean" },
        "messagingAllowed": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MinimumActiveProfileV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "displayName",
        "gameHandle",
        "rankId",
        "roleIds",
        "favoriteHeroIds",
        "timezone"
      ],
      "properties": {
        "displayName": { "type": "string", "minLength": 2, "maxLength": 40 },
        "gameHandle": { "type": "string", "minLength": 2, "maxLength": 64 },
        "rankId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "roleIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        },
        "favoriteHeroIds": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        },
        "timezone": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "CompletePlayerOnboardingCommandV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idempotencyKey", "expectedProfileVersion", "profile"],
      "properties": {
        "idempotencyKey": { "$ref": "#/schemas/IdempotencyKey" },
        "expectedProfileVersion": { "type": "integer", "minimum": 0 },
        "profile": { "$ref": "#/schemas/MinimumActiveProfileV1" }
      }
    },
    "CompletePlayerOnboardingResultV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal", "lifecycle", "profileVersion", "replayed"],
      "properties": {
        "principal": { "$ref": "#/schemas/AuthenticatedPrincipalV1" },
        "lifecycle": { "$ref": "#/schemas/PlayerLifecycleSnapshotV1" },
        "profileVersion": { "type": "integer", "minimum": 1 },
        "replayed": { "type": "boolean" }
      }
    },
    "CoreErrorCodeV1": {
      "type": "string",
      "enum": [
        "authentication_required",
        "session_expired",
        "player_not_found",
        "player_suspended",
        "player_deleting",
        "player_deleted",
        "profile_incomplete",
        "profile_version_conflict",
        "invalid_lifecycle_transition",
        "idempotency_key_reused",
        "request_validation_failed"
      ]
    },
    "CoreErrorV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "requestId", "retryable"],
      "properties": {
        "code": { "$ref": "#/schemas/CoreErrorCodeV1" },
        "message": { "type": "string", "minLength": 1, "maxLength": 500 },
        "requestId": { "$ref": "#/schemas/RequestId" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "PlayerLifecycleEventTypeV1": {
      "type": "string",
      "enum": [
        "player.activated.v1",
        "player.profile_updated.v1",
        "player.suspended.v1",
        "player.deletion_requested.v1",
        "player.deleted.v1"
      ]
    },
    "PlayerLifecycleEventV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventId",
        "eventType",
        "occurredAt",
        "accountId",
        "playerId",
        "profileId",
        "lifecycleVersion"
      ],
      "properties": {
        "eventId": { "type": "string", "format": "uuid" },
        "eventType": { "$ref": "#/schemas/PlayerLifecycleEventTypeV1" },
        "occurredAt": { "type": "string", "format": "date-time" },
        "accountId": { "$ref": "#/schemas/AccountId" },
        "playerId": { "$ref": "#/schemas/PlayerId" },
        "profileId": { "$ref": "#/schemas/ProfileId" },
        "lifecycleVersion": { "type": "integer", "minimum": 1 },
        "profileVersion": { "type": "integer", "minimum": 0 },
        "reasonCode": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    }
  },
