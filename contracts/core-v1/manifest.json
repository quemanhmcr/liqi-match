      "lifecycle.suspended",
      "lifecycle.deleting"
    ],
    "mission4.sessionAndDeepLinks": [
      "authenticatedPrincipal.valid",
      "authenticatedPrincipal.expired",
      "lifecycle.onboarding",
      "lifecycle.deleting"
    ]
  }
}
