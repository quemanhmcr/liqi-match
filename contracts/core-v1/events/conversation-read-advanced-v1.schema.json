{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.app/core-v1/conversationreadadvanced-v1.schema.json",
  "title": "ConversationReadAdvancedV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Globally unique event identifier."
    },
    "eventType": {
      "const": "conversation.read_advanced.v1"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC event time."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Cross-mission correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Identifier of the command or event that caused this event."
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "readState": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "conversationId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "description": "ConversationId."
            },
            "playerId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "description": "PlayerId."
            },
            "lastReadSequence": {
              "type": "integer",
              "minimum": 0
            },
            "unreadCount": {
              "type": "integer",
              "minimum": 0
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time",
              "description": "Authoritative server update time."
            }
          },
          "required": [
            "conversationId",
            "playerId",
            "lastReadSequence",
            "unreadCount",
            "updatedAt"
          ]
        }
      },
      "required": ["readState"]
    }
  },
  "required": ["eventId", "eventType", "occurredAt", "correlationId", "payload"]
}
