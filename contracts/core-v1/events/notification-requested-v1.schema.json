{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.app/core-v1/notificationrequested-v1.schema.json",
  "title": "NotificationRequestedV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Globally unique event identifier."
    },
    "eventType": {
      "const": "notification.requested.v1"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC event time."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Cross-mission correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Identifier of the command or event that caused this event."
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": {
          "const": "message_received"
        },
        "recipientPlayerId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "PlayerId that should receive attention."
        },
        "conversationId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "ConversationId deep-link target."
        },
        "messageId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "MessageId that triggered attention."
        },
        "senderPlayerId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "PlayerId that sent the message."
        },
        "authoritativeUnreadCount": {
          "type": "integer",
          "minimum": 1
        },
        "foregroundPolicy": {
          "enum": ["suppress_push", "allow_push"]
        }
      },
      "required": [
        "reason",
        "recipientPlayerId",
        "conversationId",
        "messageId",
        "senderPlayerId",
        "authoritativeUnreadCount",
        "foregroundPolicy"
      ]
    }
  },
  "required": ["eventId", "eventType", "occurredAt", "correlationId", "payload"]
}
