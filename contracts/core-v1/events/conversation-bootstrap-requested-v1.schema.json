{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.app/core-v1/conversationbootstraprequested-v1.schema.json",
  "title": "ConversationBootstrapRequestedV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Globally unique event identifier."
    },
    "eventType": {
      "const": "conversation.bootstrap_requested.v1"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC event time."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Cross-mission correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Identifier of the command or event that caused this event."
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "matchId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Authoritative MatchId supplied by Mission 2."
        },
        "participantIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "PlayerId supplied by Mission 2."
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Stable bootstrap idempotency key for this match."
        }
      },
      "required": ["matchId", "participantIds", "idempotencyKey"]
    }
  },
  "required": ["eventId", "eventType", "occurredAt", "correlationId", "payload"]
}
