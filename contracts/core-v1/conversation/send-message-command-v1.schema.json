{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.app/core-v1/sendmessagecommand-v1.schema.json",
  "title": "SendMessageCommandV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "conversationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "ConversationId."
    },
    "clientMessageId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Stable idempotency identifier reused for retries."
    },
    "content": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "text"
            },
            "text": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            }
          },
          "required": ["kind", "text"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "media"
            },
            "assetId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "description": "Authoritative media asset identifier."
            },
            "caption": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            }
          },
          "required": ["kind", "assetId"]
        }
      ]
    },
    "clientCreatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Client observation time; never used for canonical ordering."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Cross-mission correlation identifier."
    }
  },
  "required": [
    "conversationId",
    "clientMessageId",
    "content",
    "clientCreatedAt",
    "correlationId"
  ],
  "description": "Authenticated command to append one text or media message."
}
