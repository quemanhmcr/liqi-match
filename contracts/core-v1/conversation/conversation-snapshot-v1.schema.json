{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.app/core-v1/conversationsnapshot-v1.schema.json",
  "title": "ConversationSnapshotV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "conversationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "ConversationId."
    },
    "matchId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Authoritative MatchId."
    },
    "participantIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "description": "PlayerId."
      },
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true
    },
    "state": {
      "enum": ["open", "archived", "closed"]
    },
    "lastMessage": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "messageId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "description": "MessageId."
            },
            "senderPlayerId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "description": "PlayerId."
            },
            "sequence": {
              "type": "integer",
              "minimum": 1
            },
            "kind": {
              "enum": ["text", "media", "system"]
            },
            "preview": {
              "type": "string",
              "maxLength": 240
            },
            "createdAt": {
              "type": "string",
              "format": "date-time",
              "description": "Authoritative server creation time."
            }
          },
          "required": [
            "messageId",
            "senderPlayerId",
            "sequence",
            "kind",
            "preview",
            "createdAt"
          ]
        }
      ]
    },
    "unreadCount": {
      "type": "integer",
      "minimum": 0
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "conversationId",
    "matchId",
    "participantIds",
    "state",
    "lastMessage",
    "unreadCount",
    "version"
  ],
  "description": "Canonical conversation projection for an authenticated participant."
}
