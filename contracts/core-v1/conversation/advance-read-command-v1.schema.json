{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.app/core-v1/advancereadcommand-v1.schema.json",
  "title": "AdvanceReadCommandV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "conversationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "ConversationId."
    },
    "lastReadSequence": {
      "type": "integer",
      "minimum": 0
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Cross-mission correlation identifier."
    }
  },
  "required": ["conversationId", "lastReadSequence", "correlationId"],
  "description": "Authenticated monotonic read-watermark command."
}
