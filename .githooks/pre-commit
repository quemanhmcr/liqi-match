#!/bin/sh
set -eu

# The main Git worktree is the Liqi primary review workspace. Implementation
# commits belong in managed task worktrees or separate clean publishable worktrees.
git_dir=$(git rev-parse --absolute-git-dir)
common_dir=$(git rev-parse --path-format=absolute --git-common-dir)

git_dir=$(cd "$git_dir" && pwd -P)
common_dir=$(cd "$common_dir" && pwd -P)

if [ "$git_dir" = "$common_dir" ] && [ "${LIQI_ALLOW_PRIMARY_COMMIT:-0}" != "1" ]; then
  echo "Commit blocked: this is the Liqi Primary review workspace."
  echo "Use another branch/worktree for commit-ready work."
  echo "Managed option: npm run task:start -- <type/name>"
  echo "Recovery-only override: LIQI_ALLOW_PRIMARY_COMMIT=1 git commit ..."
  exit 1
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
if printf '%s\n' "$staged_files" | grep -Eq '^(DESIGN\.md|config/design-system-|docs/(design/|adr/0009-)|src/(app-shell|features|shared/components|shared/layouts|shared/theme|shared/ui)/.*\.(ts|tsx)|scripts/(check-design-system|design/)|package(-lock)?\.json)'; then
  echo "Checking LiQi shared UI contract..."
  node scripts/check-design-system.cjs
fi

exit 0
