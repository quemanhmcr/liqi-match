{
  "name": "liqi_match",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~56.0.15",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.20",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.22",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.20",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-media-library": "~56.0.9",
    "expo-router": "~56.2.14",
    "expo-sharing": "~56.0.21",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.80.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "json-schema-to-zod": "^2.8.1"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "dev:android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-android.ps1",
    "dev:android:rebuild": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-android.ps1 -Rebuild",
    "dev:android:rebuild:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-android.ps1 -Rebuild -CleanPrebuild",
    "dev:android:clear": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-android.ps1 -ClearMetroCache",
    "dev:android:takeover": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-android.ps1 -ForceTakeoverPort",
    "dev:android:cold": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-android.ps1 -ColdBoot",
    "repo:setup": "git config core.hooksPath .githooks && node scripts/repository-context.cjs",
    "repo:context": "node scripts/repository-context.cjs",
    "repository:check": "node scripts/check-repository-contract.cjs",
    "prepare:git": "npm run repo:setup",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "assets:generate": "node scripts/generate-asset-manifest.cjs",
    "assets:check": "node scripts/lib/image-metadata.test.cjs && node scripts/generate-asset-manifest.cjs --check && node scripts/validate-assets.cjs",
    "assets:validate": "node scripts/validate-assets.cjs",
    "architecture:check": "node scripts/check-architecture.cjs && npm run backend:architecture:check",
    "backend:architecture:check": "node scripts/check-backend-architecture.cjs",
    "test": "node scripts/run-jest.cjs --watch --onlyChanged",
    "test:ci": "npm run test:full",
    "supabase:start": "supabase start",
    "supabase:reset": "supabase db reset",
    "supabase:lint": "supabase db lint",
    "supabase:test": "supabase test db",
    "supabase:types": "supabase gen types typescript --local > src/shared/types/database.types.ts",
    "cloudflare:media:install": "npm --prefix cloudflare/media-worker ci",
    "cloudflare:media:typecheck": "npm --prefix cloudflare/media-worker run typecheck",
    "cloudflare:media:test": "npm --prefix cloudflare/media-worker test",
    "cloudflare:media:dry-run": "npm --prefix cloudflare/media-worker run deploy:dry-run",
    "postinstall": "patch-package",
    "test:unit": "node scripts/run-jest.cjs --config jest.unit.config.js",
    "test:unit:watch": "node scripts/run-jest.cjs --config jest.unit.config.js --watch --onlyChanged",
    "test:native": "node scripts/run-jest.cjs --config jest.native.config.js",
    "test:native:watch": "node scripts/run-jest.cjs --config jest.native.config.js --watch --onlyChanged",
    "test:changed": "node scripts/run-jest.cjs --changedSince=HEAD",
    "test:failed": "node scripts/run-jest.cjs --onlyFailures",
    "test:full": "npm run test:policy && npm run test:unit && npm run test:native",
    "test:related": "node scripts/run-jest.cjs --findRelatedTests",
    "test:policy": "node scripts/check-test-policy.cjs",
    "security:audit": "npm audit --audit-level=moderate",
    "test:native:handles": "jest --config jest.native.config.js --runInBand --detectOpenHandles",
    "worktree:create": "node scripts/worktree/worktree-cli.cjs create",
    "worktree:overlay": "node scripts/worktree/worktree-cli.cjs overlay",
    "worktree:rollback": "node scripts/worktree/worktree-cli.cjs rollback",
    "worktree:cleanup": "node scripts/worktree/worktree-cli.cjs cleanup",
    "worktree:doctor": "node scripts/worktree/worktree-cli.cjs doctor",
    "worktree:list": "node scripts/worktree/worktree-cli.cjs list",
    "worktree:self-test": "node scripts/worktree/self-test.cjs",
    "task:start": "node scripts/worktree/worktree-cli.cjs create",
    "task:inspect": "node scripts/worktree/worktree-cli.cjs doctor",
    "task:list": "node scripts/worktree/worktree-cli.cjs list",
    "task:check": "npm run repository:check && npm run contracts:check && npm run match-authority:check && npm run discovery-authority:check && npm run match-conversation-projection:check && npm run assets:check && npm run format:check && npm run architecture:check && npm run security:audit && npm run lint && npm run typecheck && npm run test:ci",
    "task:review": "node scripts/worktree/worktree-cli.cjs overlay",
    "task:undo": "node scripts/worktree/worktree-cli.cjs rollback",
    "task:finish": "node scripts/worktree/worktree-cli.cjs cleanup",
    "contracts:check": "node scripts/contracts/check-core-v1-contracts.cjs && node scripts/run-jest.cjs --config jest.unit.config.js --runTestsByPath src/contracts/__tests__/core-v1-contracts.test.ts src/contracts/__tests__/mission1-provider-contracts.test.ts src/contracts/__tests__/conversation-v1-contracts.test.ts",
    "match-authority:check": "node scripts/contracts/check-match-authority-v1.cjs",
    "discovery-authority:check": "node scripts/contracts/check-discovery-authority-v1.cjs",
    "match-conversation-projection:check": "node scripts/contracts/check-match-conversation-projection-v1.cjs",
    "match-authority-rollout:check": "node scripts/contracts/check-match-authority-rollout-v1.cjs",
    "match-funnel-telemetry:check": "node scripts/contracts/check-match-funnel-telemetry-v1.cjs"
  },
  "overrides": {
    "xcode": {
      "uuid": "11.1.1"
    }
  }
}
